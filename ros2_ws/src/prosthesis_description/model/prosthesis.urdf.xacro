<?xml version="1.0"?>
<robot name="prosthesis" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--File containing all the fundamental links and joints description-->
  <xacro:include filename="$(find prosthesis_description)/model/parameters.xacro" />
  <!-- File containing all the neccessary parameters for Gazebo-ROS bridge-->
  <xacro:include filename="$(find prosthesis_description)/model/gazebo.xacro" />

    <!-- ===== LINKS (base & palm unchanged) ===== -->
    <link name="world" />
    
    <!-- Intermediate kinematic links for base movement (x, y, z) -->
    <link name="base_link_x_frame">
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
      </inertial>
    </link>

    <link name="base_link_y_frame">
      <inertial>
        <mass value="0.001"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
      </inertial>
    </link>
    
    <link name="base_link">
      <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><box size="${base_length} ${base_width} ${base_depth}"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><box size="${base_length} ${base_width} ${base_depth}"/></geometry>
      </collision>
      <xacro:inertial_box mass="1.0" x="${base_length}" y="${base_width}" z="${base_depth}">
          <origin xyz="0 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <xacro:property name="wrist_radius" value="${base_width/2}" />

      <link name="wrist_link">
      <visual>
          <origin xyz="${wrist_radius} 0 0" rpy="0 0 0"/>
          <geometry><sphere radius="${wrist_radius}"/></geometry>
      </visual>
      <collision>
          <origin xyz="${wrist_radius} 0 0" rpy="0 0 0"/>
          <geometry><sphere radius="${wrist_radius}"/></geometry>
      </collision>
      <xacro:inertial_sphere mass="0.2" radius="${wrist_radius}">
          <origin xyz="${wrist_radius} 0 0" rpy="0 0 0"/>
      </xacro:inertial_sphere>
    </link>

    <link name="palm_link">
      <visual>
          <origin xyz="${palm_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${palm_length} ${palm_width} ${palm_depth}"/></geometry>
      </visual>
      <collision>
          <origin xyz="${palm_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${palm_length} ${palm_width} ${palm_depth}"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.2" x="${palm_length}" y="${palm_width}" z="${palm_depth}">
          <origin xyz="${palm_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>



    <!-- ===== FINGER & THUMB LINKS (all boxes 0.02 x 0.05 x 0.02) ===== -->
    <!-- Index -->
    
    <link name="link_index_1">
      <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_3.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_3.stl"/></geometry>
          <!--<origin xyz="${index_proximal_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${index_proximal_length} ${index_proximal_width} ${index_proximal_depth}"/></geometry>-->
      </collision>
      <xacro:inertial_box mass="0.01" x="${finger_proximal_length}" y="${finger_proximal_width}" z="${finger_proximal_depth}">
          <origin xyz="${finger_proximal_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_index_2">
      <visual>
          <!--<origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_4.stl"/></geometry>-->
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${finger_middle_length/4} ${finger_middle_width} ${finger_middle_depth}"/></geometry>
      </visual>
      <collision>
          <!--<origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_4.stl"/></geometry>-->
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${finger_middle_length} ${finger_middle_width} ${finger_middle_depth}"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_index_3">
      <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_5.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_5.stl"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_index_4">
      <visual>
          <origin xyz="0 0 0" rpy="-1.57 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_6.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="-1.57 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_6.stl"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="index_middle_fsr_link">
      <visual>
          <origin xyz="${finger_middle_length/2} 0 -0.005" rpy="0 0 0"/>
          <geometry><sphere radius="0.005"/></geometry>
      </visual>
      <collision>
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
          <geometry><sphere radius="0.005"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>



    <!-- Middle -->
    
    <link name="link_middle_1">
      <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_3.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_3.stl"/></geometry>
          <!--<origin xyz="${index_proximal_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${index_proximal_length} ${index_proximal_width} ${index_proximal_depth}"/></geometry>-->
      </collision>
      <xacro:inertial_box mass="0.01" x="${finger_proximal_length}" y="${finger_proximal_width}" z="${finger_proximal_depth}">
          <origin xyz="${finger_proximal_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_middle_2">
      <visual>
          <!--<origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_4.stl"/></geometry>-->
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${finger_middle_length/4} ${finger_middle_width} ${finger_middle_depth}"/></geometry>
      </visual>
      <collision>
          <!--<origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_4.stl"/></geometry>-->
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${finger_middle_length} ${finger_middle_width} ${finger_middle_depth}"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_middle_3">
      <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_5.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_5.stl"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_middle_4">
      <visual>
          <origin xyz="0 0 0" rpy="-1.57 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_6.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="-1.57 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_6.stl"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <!-- Ring -->
    
    <link name="link_ring_1">
      <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_3.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_3.stl"/></geometry>
          <!--<origin xyz="${index_proximal_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${index_proximal_length} ${index_proximal_width} ${index_proximal_depth}"/></geometry>-->
      </collision>
      <xacro:inertial_box mass="0.01" x="${finger_proximal_length}" y="${finger_proximal_width}" z="${finger_proximal_depth}">
          <origin xyz="${finger_proximal_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_ring_2">
      <visual>
          <!--<origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_4.stl"/></geometry>-->
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${finger_middle_length/4} ${finger_middle_width} ${finger_middle_depth}"/></geometry>
      </visual>
      <collision>
          <!--<origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_4.stl"/></geometry>-->
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${finger_middle_length} ${finger_middle_width} ${finger_middle_depth}"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_ring_3">
      <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_5.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_5.stl"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_ring_4">
      <visual>
          <origin xyz="0 0 0" rpy="-1.57 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_6.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="-1.57 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_6.stl"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <!-- Little -->
    
    <link name="link_little_1">
      <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_3.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_3.stl"/></geometry>
          <!--<origin xyz="${index_proximal_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${index_proximal_length} ${index_proximal_width} ${index_proximal_depth}"/></geometry>-->
      </collision>
      <xacro:inertial_box mass="0.01" x="${finger_proximal_length}" y="${finger_proximal_width}" z="${finger_proximal_depth}">
          <origin xyz="${finger_proximal_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_little_2">
      <visual>
          <!--<origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_4.stl"/></geometry>-->
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${finger_middle_length/4} ${finger_middle_width} ${finger_middle_depth}"/></geometry>
      </visual>
      <collision>
          <!--<origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_4.stl"/></geometry>-->
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${finger_middle_length} ${finger_middle_width} ${finger_middle_depth}"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_little_3">
      <visual>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_5.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_5.stl"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_little_4">
      <visual>
          <origin xyz="0 0 0" rpy="-1.57 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_6.stl"/></geometry>
      </visual>
      <collision>
          <origin xyz="0 0 0" rpy="-1.57 0 0"/>
          <geometry><mesh filename="$(find prosthesis_description)/meshes/PhalangeConstruction_Part_6.stl"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.02" x="${finger_middle_length}" y="${finger_middle_width}" z="${finger_middle_depth}">
          <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <!-- Thumb -->

    <link name="link_thumb_1">
      <visual>
          <origin xyz="${thumb_metacarpal_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${thumb_metacarpal_length} ${thumb_metacarpal_width} ${thumb_metacarpal_depth}"/></geometry>
      </visual>
      <collision>
          <origin xyz="${thumb_metacarpal_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${thumb_metacarpal_length} ${thumb_metacarpal_width} ${thumb_metacarpal_depth}"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.01" x="${thumb_metacarpal_length}" y="${thumb_metacarpal_width}" z="${thumb_metacarpal_depth}">
          <origin xyz="${thumb_metacarpal_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_thumb_2">
      <visual>
          <origin xyz="${thumb_proximal_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${thumb_proximal_length} ${thumb_proximal_width} ${thumb_proximal_depth}"/></geometry>
      </visual>
      <collision>
          <origin xyz="${thumb_proximal_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${thumb_proximal_length} ${thumb_proximal_width} ${thumb_proximal_depth}"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.01" x="${thumb_proximal_length}" y="${thumb_proximal_width}" z="${thumb_proximal_depth}">
          <origin xyz="${thumb_proximal_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <link name="link_thumb_3">
      <visual>
          <origin xyz="${thumb_distal_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${thumb_distal_length} ${thumb_distal_width} ${thumb_distal_depth}"/></geometry>
      </visual>
      <collision>
          <origin xyz="${thumb_distal_length/2} 0 0" rpy="0 0 0"/>
          <geometry><box size="${thumb_distal_length} ${thumb_distal_width} ${thumb_distal_depth}"/></geometry>
      </collision>
      <xacro:inertial_box mass="0.01" x="${thumb_distal_length}" y="${thumb_distal_width}" z="${thumb_distal_depth}">
          <origin xyz="${thumb_distal_length/2} 0 0" rpy="0 0 0"/>
      </xacro:inertial_box>
    </link>

    <!-- ===== JOINTS ===== -->
    <!-- World → Base X (prismatic joint for x-axis motion) -->
    <joint name="joint_world_to_base_x" type="prismatic">
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <parent link="world"/>
          <child link="base_link_x_frame"/>
          <axis xyz="1 0 0"/>
          <limit lower="-2.0" upper="2.0" effort="100" velocity="1.0"/>
    </joint>

    <!-- Base X → Base Y (prismatic joint for y-axis motion) -->
    <joint name="joint_base_x_to_base_y" type="prismatic">
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <parent link="base_link_x_frame"/>
          <child link="base_link_y_frame"/>
          <axis xyz="0 1 0"/>
          <limit lower="-2.0" upper="2.0" effort="100" velocity="1.0"/>
    </joint>

    <!-- Base Y → Base Link (prismatic joint for z-axis motion) -->
    <joint name="joint_base_y_to_base_z" type="prismatic">
          <origin xyz="0 0 0" rpy="0 0 0"/>
          <parent link="base_link_y_frame"/>
          <child link="base_link"/>
          <axis xyz="0 0 1"/>
          <limit lower="0.0" upper="2.0" effort="100" velocity="1.0"/>
    </joint>

    <!-- Base → Wrist -->
    <joint name="joint_base_to_wrist" type="fixed">
      <parent link="base_link"/>
      <child  link="wrist_link"/>
      <origin xyz="${base_length/2} 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Wrist → Palm -->
    <joint name="joint_wrist_to_palm" type="revolute">
      <parent link="wrist_link"/>
      <child  link="palm_link"/>
      <origin xyz="${wrist_radius*2} 0 0" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1.57" upper="1.57" effort="5" velocity="5"/>
    </joint>

    <!-- Index -->
    <joint name="joint_index_1" type="revolute">
      <parent link="palm_link"/><child link="link_index_1"/>
      <origin xyz="${mcp_x} ${index_mcp_y} 0.0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="3" velocity="5"/>
    </joint>
    <joint name="joint_index_2" type="revolute">
      <parent link="link_index_1"/><child link="link_index_2"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>
    <joint name="joint_index_3" type="revolute">
      <parent link="link_index_2"/><child link="link_index_3"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>
    <joint name="joint_index_4" type="revolute">
      <parent link="link_index_3"/><child link="link_index_4"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>
    <joint name="joint_index_fsr" type="fixed">
      <parent link="link_index_4"/><child link="index_middle_fsr_link"/>
      <origin xyz="${finger_middle_length/2} 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Middle -->
    <joint name="joint_middle_1" type="revolute">
      <parent link="palm_link"/><child link="link_middle_1"/>
      <origin xyz="${mcp_x} ${middle_mcp_y} 0.0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="3" velocity="5"/>
    </joint>
    <joint name="joint_middle_2" type="revolute">
      <parent link="link_middle_1"/><child link="link_middle_2"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>
    <joint name="joint_middle_3" type="revolute">
      <parent link="link_middle_2"/><child link="link_middle_3"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>
    <joint name="joint_middle_4" type="revolute">
      <parent link="link_middle_3"/><child link="link_middle_4"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>

    <!-- Ring -->
    <joint name="joint_ring_1" type="revolute">
      <parent link="palm_link"/><child link="link_ring_1"/>
      <origin xyz="${mcp_x} ${ring_mcp_y} 0.0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="3" velocity="5"/>
    </joint>
    <joint name="joint_ring_2" type="revolute">
      <parent link="link_ring_1"/><child link="link_ring_2"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>
    <joint name="joint_ring_3" type="revolute">
      <parent link="link_ring_2"/><child link="link_ring_3"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>
    <joint name="joint_ring_4" type="revolute">
      <parent link="link_ring_3"/><child link="link_ring_4"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>

    <!-- Little -->
    <joint name="joint_little_1" type="revolute">
      <parent link="palm_link"/><child link="link_little_1"/>
      <origin xyz="${mcp_x} ${little_mcp_y} 0.0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="3" velocity="5"/>
    </joint>
    <joint name="joint_little_2" type="revolute">
      <parent link="link_little_1"/><child link="link_little_2"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>
    <joint name="joint_little_3" type="revolute">
      <parent link="link_little_2"/><child link="link_little_3"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>
    <joint name="joint_little_4" type="revolute">
      <parent link="link_little_3"/><child link="link_little_4"/>
      <origin xyz="${finger_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>

    <!-- Thumb (diagonal) -->
    <joint name="joint_thumb_1" type="revolute">
      <parent link="palm_link"/><child link="link_thumb_1"/>
      <origin xyz="${thumb_metacarpal_width/2 + 0.02} ${-(palm_width/2) - 0.0068} 0.00" rpy="0 0 -0.80"/><axis xyz="0 1 0"/>
      <limit lower="-0.40" upper="1.20" effort="3" velocity="5"/>
    </joint>
    <joint name="joint_thumb_2" type="revolute">
      <parent link="link_thumb_1"/><child link="link_thumb_2"/>
      <origin xyz="${thumb_metacarpal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>
    <joint name="joint_thumb_3" type="revolute">
      <parent link="link_thumb_2"/><child link="link_thumb_3"/>
      <origin xyz="${thumb_proximal_length} 0 0" rpy="0 0 0"/><axis xyz="0 1 0"/>
      <limit lower="0.0" upper="1.57" effort="2" velocity="5"/>
    </joint>


      <!-- ===== ROS2 CONTROL INTERFACE ===== -->
  <!-- Tells control_manager what hardware plugin to instanciate,
   which joint exists and which interface each joint exposes -->

  <ros2_control name="GazeboSimROS2ControlPlugin" type="system">

    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- Base Movement Joints (X, Y, Z) -->
    <joint name="joint_world_to_base_x">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_base_x_to_base_y">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_base_y_to_base_z">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Wrist Joint -->
    <joint name="joint_wrist_to_palm">
      <command_interface name="position"/> <!-- command controller will send for position control -->
      <state_interface name="position"/> <!-- state controller can read -->
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Index Finger Joints -->
    <joint name="joint_index_1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_index_2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_index_3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
      <joint name="joint_index_4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Middle Finger Joints -->
    <joint name="joint_middle_1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_middle_2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_middle_3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
      <joint name="joint_middle_4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Ring Finger Joints -->
    <joint name="joint_ring_1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_ring_2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_ring_3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
      <joint name="joint_ring_4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Little Finger Joints -->
    <joint name="joint_little_1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_little_2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_little_3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
      <joint name="joint_little_4">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Thumb Joints -->
    <joint name="joint_thumb_1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_thumb_2">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="joint_thumb_3">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

  </ros2_control>

</robot>